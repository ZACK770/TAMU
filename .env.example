# Database
DATABASE_URL=postgresql://user:password@host:5432/database?schema=public

# Server
PORT=9000
NODE_ENV=development

# JWT Secret
JWT_SECRET=your-secret-key-change-in-production

# Yemot HaMashiach API
# Username should be the system number (e.g., 0770000000)
# Password should be the management password
YEMOT_API_USERNAME=0770000000
YEMOT_API_PASSWORD=1234

# CORS
FRONTEND_URL=http://localhost:5173
